{
  "name": "gobunnyy-backend-workers",
  "version": "1.0.0",
  "description": "Cloudflare Workers backend for GoBunnyy",
  "main": "worker.js",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create godashprodcore01",
    "db:migrate": "wrangler d1 execute godashprodcore01 --file=./database/d1-schema.sql",
    "db:local": "wrangler d1 execute godashprodcore01 --local --file=./database/d1-schema.sql"
  },
  "dependencies": {},
  "devDependencies": {
    "wrangler": "^3.0.0"
  }
}

