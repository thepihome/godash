{
  "name": "gobunny-playwright-tests",
  "version": "1.0.0",
  "private": true,
  "description": "Local-only Playwright tests for GoBunny app",
  "scripts": {
    "test": "node -r dotenv/config node_modules/@playwright/test/cli.js test",
    "test:smoke": "node -r dotenv/config node_modules/@playwright/test/cli.js test smoke",
    "test:sanity": "node -r dotenv/config node_modules/@playwright/test/cli.js test sanity",
    "test:regression": "node -r dotenv/config node_modules/@playwright/test/cli.js test regression",
    "test:ui": "node -r dotenv/config node_modules/@playwright/test/cli.js test --ui",
    "report": "node node_modules/@playwright/test/cli.js show-report",
    "install-browsers": "npx playwright install chromium"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "dotenv": "^16.4.5"
  }
}
