# Local-only Playwright configuration
# Copy to .env and adjust for your machine

# App URL (React dev server or local build)
PLAYWRIGHT_BASE_URL=http://localhost:3000

# API URL used for mock routing (should match REACT_APP_API_URL)
PLAYWRIGHT_API_URL=http://localhost:5023/api

# Default role for authenticated tests: admin | consultant | candidate
PLAYWRIGHT_TEST_ROLE=admin

# Use dev server instead of static build: PLAYWRIGHT_WEB_COMMAND="npm start"
# Skip auto-start if app is already running: PLAYWRIGHT_SKIP_WEBSERVER=true
# Use system Chrome if bundled Chromium fails to install: PLAYWRIGHT_CHANNEL=chrome
PLAYWRIGHT_ALLOW_REMOTE=false
