# index.html must always be fresh so it references the correct hashed bundles.
/index.html
  Cache-Control: no-cache, no-store, must-revalidate

/
  Cache-Control: no-cache, must-revalidate

# Hashed assets: long cache but NOT immutable — prevents CDN from locking in
# a mistaken index.html response if a bundle is briefly missing during deploy.
/static/*
  Cache-Control: public, max-age=31536000, must-revalidate
