# Shell must always be fresh so it references the correct hashed bundles.
/index.html
  Cache-Control: no-cache, no-store, must-revalidate
  CDN-Cache-Control: no-store

/
  Cache-Control: no-cache, must-revalidate
  CDN-Cache-Control: no-store

# JS bundles — explicit MIME type; shorter edge TTL on custom domains avoids
# locking in a mistaken index.html response at /static/js/*.js
/static/js/*
  Content-Type: application/javascript
  Cache-Control: public, max-age=31536000, must-revalidate
  CDN-Cache-Control: max-age=3600, must-revalidate

/static/css/*
  Content-Type: text/css
  Cache-Control: public, max-age=31536000, must-revalidate
  CDN-Cache-Control: max-age=3600, must-revalidate

/static/*
  Cache-Control: public, max-age=31536000, must-revalidate
  CDN-Cache-Control: max-age=3600, must-revalidate
