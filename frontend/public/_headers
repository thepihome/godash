# Cloudflare Pages / Netlify: avoid serving a cached index.html that references old hashed JS/CSS.
# Hashed assets under /static/ can stay cached long-term.

/static/*
  Cache-Control: public, max-age=31536000, immutable

/
  Cache-Control: no-cache, must-revalidate

/index.html
  Cache-Control: no-cache, must-revalidate
